// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String   @id @default(cuid())
  email             String?  @unique
  username          String?
  provider          String? // google / naver / kakao
  providerAccountId String? // OAuth 고유 id (이메일 없을 때 upsert 기준)
  role              UserRole @default(GENERAL)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([provider, providerAccountId])
}

enum UserRole {
  GENERAL
  SUPER_ADMIN
}

model Team {
  id          String    @id @default(cuid())
  name        String
  sport_type  SportType
  logo        String?
  color       String?   // 팀 대표 색깔 (hex 코드)
  access_code String    @unique
  operator    String
  admins      String[]
  players     Player[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Player {
  id        String       @id @default(cuid())
  name      String
  photo     String?
  position  Position[]
  style     PlayerStyle
  teamId    String
  team      Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  isActive  Boolean      @default(true)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([teamId, createdAt])
}

enum SportType {
  FUTSAL
  SOCCER
}

enum PlayerStyle {
  OFFENSIVE
  BALANCED
  DEFENSIVE
  GOALKEEPER
}

enum Position {
  FW
  MF
  DF
  GK
}
