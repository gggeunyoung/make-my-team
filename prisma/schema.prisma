// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String   @id @default(cuid())
  email             String?  @unique
  username          String?
  provider          String? // google / naver / kakao
  providerAccountId String? // OAuth 고유 id (이메일 없을 때 upsert 기준)
  role              UserRole @default(GENERAL)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([provider, providerAccountId])
}

enum UserRole {
  GENERAL
  SUPER_ADMIN
}

model Team {
  id          String       @id @default(cuid())
  name        String
  sport_type  SportType
  logo        String?
  color       String? // 팀 대표 색깔 (hex 코드)
  access_code String       @unique
  operator    String
  admins      String[]
  players     Player[]
  matches     Match[]
  playerStats Player_Stat[]
  duoStats    Duo_Stat[]
  tournaments Tournament[]
  awards      Award[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Tournament {
  id                String            @id @default(cuid())
  tournament_name   String?
  tournament_result TournamentResult?
  start_date        DateTime?
  finish_date       DateTime?
  attendees         String[]
  pick_1st          String?
  pick_2nd          String?
  pick_3rd          String?
  v_score1          Float?
  v_score2          Float?
  v_score3          Float?
  v_score_others    Float?
  final_mvp         String?
  is_completed      Boolean           @default(false)
  teamId            String
  team              Team              @relation(fields: [teamId], references: [id], onDelete: Cascade)
  matches           Match[]
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([teamId, is_completed])
}

model Player {
  id        String       @id @default(cuid())
  name      String
  photo     String?
  position  Position[]
  style     PlayerStyle
  teamId    String
  team      Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  playerStats Player_Stat[]
  duoStatsA   Duo_Stat[] @relation("DuoStatA")
  duoStatsB   Duo_Stat[] @relation("DuoStatB")
  awards      Award[]
  isActive  Boolean      @default(true)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([teamId, createdAt])
}

model Match {
  id               String           @id @default(cuid())
  teamId           String
  team             Team             @relation(fields: [teamId], references: [id])
  opponent_name    String
  opponent_level   OpponentLevel
  date             DateTime
  attendees        String[] // Player id 목록
  total_score_us   Int              @default(0)
  total_score_them Int              @default(0)
  total_result     MatchResult
  count_win        Int              @default(0)
  count_draw       Int              @default(0)
  count_loss       Int              @default(0)
  is_tournament    Boolean          @default(false)
  is_pso           Boolean          @default(false)
  pso_result       PsoResult?
  match_format_futsal MatchFormatFutsal?
  stage            TournamentStage?
  tournamentId     String?
  tournament       Tournament?      @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  mom              String? // Player id
  games            Game[]
  playerStats      Player_Stat[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([teamId, date])
  @@index([tournamentId])
}

enum MatchFormatFutsal {
  FIVE_VS_FIVE
  SIX_VS_SIX
}

model Game {
  id          String      @id @default(cuid())
  matchId     String
  match       Match       @relation(fields: [matchId], references: [id], onDelete: Cascade)
  score_us    Int
  score_them  Int
  result      MatchResult
  players_all String[]
  players_fw  String[]
  players_mf  String[]
  players_df  String[]
  players_gk  String[]
  goal_events GoalEvent[]
  createdAt   DateTime    @default(now())
}

model GoalEvent {
  id            String     @id @default(cuid())
  gameId        String
  game          Game       @relation(fields: [gameId], references: [id], onDelete: Cascade)
  matchId       String
  scorer_id     String?
  scorer_type   RecordType
  assister_id   String?
  assister_type RecordType
  createdAt     DateTime   @default(now())
}

model Player_Stat {
  id                String         @id @default(cuid())
  player            Player         @relation(fields: [playerId], references: [id])
  playerId          String
  match             Match          @relation(fields: [matchId], references: [id])
  matchId           String
  team              Team           @relation(fields: [teamId], references: [id])
  teamId            String
  goals             Int            @default(0)
  assist            Int            @default(0)
  attack_point      Int            @default(0)
  perf_attack       Float          @default(0)
  perf_defense      Float          @default(0)
  perf_total        Float          @default(0)
  is_clean_sheet    Boolean        @default(false)
  is_mom            Boolean        @default(false)
  is_tournament     Boolean        @default(false)
  match_date        DateTime
  opponent_level    OpponentLevel
  snapshot_position Position? // 축구일 때만 사용
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
}

model Duo_Stat {
  id          String   @id @default(cuid())
  player_A    Player   @relation("DuoStatA", fields: [playerAId], references: [id])
  playerAId   String
  player_B    Player   @relation("DuoStatB", fields: [playerBId], references: [id])
  playerBId   String
  team        Team     @relation(fields: [teamId], references: [id])
  teamId      String
  joint_goals Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([playerAId, playerBId, teamId])
}

model Award {
  id         String        @id @default(cuid())
  playerId   String
  player     Player        @relation(fields: [playerId], references: [id])
  teamId     String
  team       Team          @relation(fields: [teamId], references: [id])
  period     AwardPeriod
  subPeriod  String
  category   AwardCategory
  rank       Int
  statValue  Float
  createdAt  DateTime      @default(now())

  @@unique([teamId, period, subPeriod, category, rank])
}

enum SportType {
  FUTSAL
  SOCCER
}

enum PlayerStyle {
  OFFENSIVE
  BALANCED
  DEFENSIVE
  GOALKEEPER
}

enum Position {
  FW
  MF
  DF
  GK
}

enum OpponentLevel {
  TOP
  HIGH
  MID
  LOW
}

enum MatchResult {
  WIN
  DRAW
  LOSS
}

enum RecordType {
  PLAYER
  MERCENARY
  OWN_GOAL
  NONE
}

enum PsoResult {
  WIN
  LOSS
}

enum TournamentStage {
  PRELIMINARY
  MAIN
}

enum TournamentResult {
  WINNER
  RUNNER_UP
  THIRD
  SEMIFINAL
  GROUP_STAGE
}

enum AwardPeriod {
  MONTHLY
  QUARTERLY
  SEMIANNUAL
  ANNUAL
}

enum AwardCategory {
  ATTACK_RANKING
  DEFENSE_RANKING
  ATTACK_COMBO
  TOP_SCORER
  TOP_ASSIST
  ATTACK_POINT
  STRONG_VS_TOP
  STRONG_VS_LOW
  ATTENDANCE
  BEST_PLAYER
}
